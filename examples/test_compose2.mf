def add1(n) = n + 1
def times2(n) = n * 2
let not_even = not . even
let increment_then_double = times2 . add1
let process_str = str.strip . str.upper

print("not . even applied to 4:", not_even(4))
print("not . even applied to 3:", not_even(3))
print("(times2 . add1)(5) =", increment_then_double(5))
print("str pipeline result:", process_str("  hello  "))

def square(n) = n * n
let complex_fn = str . times2 . square . add1
print("complex_fn(3) =", complex_fn(3))

let text = "hello world"
let word_freq = text.split(" ") |> sorted
print("Words:", word_freq)
